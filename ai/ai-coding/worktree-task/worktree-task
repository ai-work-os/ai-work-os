#!/usr/bin/env bash
# worktree-task — 多仓库任务工作区管理(非交互、项目无关、读 JSON 配置)
#
#   worktree-task create --config <p> --task <id> --repos <r1,r2>
#   worktree-task list   --config <p>
#   worktree-task remove --config <p> --task <id>
set -euo pipefail

die() { echo "worktree-task: $*" >&2; exit 1; }
log() { echo "[worktree-task] $*" >&2; }
usage() {
  cat >&2 <<'EOF'
worktree-task — 多仓库任务工作区管理

用法:
  worktree-task create --config <p> --task <id> [--type feat|fix|refactor|docs|chore] [--repos <r1,r2>]
  worktree-task list   --config <p>
  worktree-task remove --config <p> --task <id>

注:
  - --type 缺省 feat。分支名 <type>/<task-id>(如 feat/retry-logic-0526)
  - --repos 不传时默认 config 里所有 repos(全切,省得判断)
  - 配置里有 "path": "." 的 root repo,worktree 占 $task_dir 顶层,
    其他子 repos 嵌套在 $task_dir/<repo>/ 下(跟主仓库结构一致)
EOF
}

cmd="${1:-}"
shift || true

config="" task="" repos="" type=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --config) config="$2"; shift 2 ;;
    --task)   task="$2";   shift 2 ;;
    --repos)  repos="$2";  shift 2 ;;
    --type)   type="$2";   shift 2 ;;
    *) shift ;;
  esac
done

case "$cmd" in create|list|remove)
  [[ -f "$config" ]] || die "config 文件不存在: ${config:-（未提供 --config）}"
;; esac

case "$cmd" in
  create)
    repos_root="$(jq -r '.repos_root' "$config")"
    worktree_root="$(jq -r '.worktree_root' "$config")"
    task_dir="$worktree_root/$task"
    [[ -e "$task_dir" ]] && die "任务工作区已存在: $task_dir（先 remove,或换 task id）"
    # 不传 --repos 时默认所有 config 里的 repos(全切,省得判定哪些用得到)
    if [[ -z "$repos" ]]; then
      repos="$(jq -r '.repos | keys | join(",")' "$config")"
    fi
    # 分支命名:遵循 git flow 前缀(feat/fix/refactor/docs/chore/...),不带前缀默认 feat
    : "${type:=feat}"
    branch_name="$type/$task"
    log "create task=$task type=$type repos=$repos config=$config"
    log "  branch will be: $branch_name"
    mkdir -p "$worktree_root"

    # 工具函数:解析 repo path
    resolve_repo_path() {
      local repo="$1"
      local path_override
      path_override="$(jq -r --arg r "$repo" '.repos[$r].path // ""' "$config")"
      if [[ -z "$path_override" ]]; then
        echo "$repos_root/$repo"
      elif [[ "$path_override" == "." ]]; then
        echo "$repos_root"
      elif [[ "$path_override" == /* ]]; then
        echo "$path_override"
      else
        echo "$repos_root/$path_override"
      fi
    }

    # 工具函数:解析远端。配置优先;缺省时 root repo 尝试从本地 base 的 upstream 推断,
    # 其他 repo 默认 origin。只解析 remote 名,不允许静默使用本地旧分支。
    resolve_remote() {
      local repo_path="$1" base="$2" repo="$3" path_override="$4"
      local remote
      remote="$(jq -r --arg r "$repo" '.repos[$r].remote // ""' "$config")"
      if [[ -z "$remote" && "$path_override" == "." ]]; then
        remote="$(git -C "$repo_path" config --get "branch.$base.remote" || true)"
      fi
      : "${remote:=origin}"
      git -C "$repo_path" remote get-url "$remote" >/dev/null 2>&1 \
        || die "remote 不存在: repo=$repo remote=$remote base=$base"
      echo "$remote"
    }

    # 工具函数:刷新并解析远端基线,输出 remote|base|hash。
    resolve_baseline() {
      local repo_path="$1" base="$2" repo="$3"
      local path_override remote hash
      path_override="$(jq -r --arg r "$repo" '.repos[$r].path // ""' "$config")"
      remote="$(resolve_remote "$repo_path" "$base" "$repo" "$path_override")"
      log "  fetch baseline: $repo $remote/$base"
      git -C "$repo_path" fetch --prune "$remote" "+refs/heads/$base:refs/remotes/$remote/$base" \
        || die "fetch 基线失败: repo=$repo remote=$remote base=$base"
      hash="$(git -C "$repo_path" rev-parse --verify "refs/remotes/$remote/$base^{commit}" 2>/dev/null)" \
        || die "远端基线不存在: repo=$repo remote=$remote base=$base"
      echo "$remote|$base|$hash"
    }

    # 分两轮处理:
    # 1) path="." 的 root repo 的 worktree target 是 $task_dir 本身(占顶层),
    #    且必须先处理(它创建 $task_dir 这个目录,其他 repo 才能嵌套进去)
    # 2) 其他子 repo 的 worktree target 是 $task_dir/$repo(嵌套位置,被 root 的 .gitignore 屏蔽)
    IFS=',' read -ra repo_list <<< "$repos"
    baseline_records=()

    root_repo=""
    sub_repos=()
    for repo in "${repo_list[@]}"; do
      path_override="$(jq -r --arg r "$repo" '.repos[$r].path // ""' "$config")"
      if [[ "$path_override" == "." ]]; then
        [[ -n "$root_repo" ]] && die "只能有一个 root repo(path=\".\"): 已有 $root_repo,又来 $repo"
        root_repo="$repo"
      else
        sub_repos+=("$repo")
      fi
    done

    # 第一轮:root repo(如有)
    if [[ -n "$root_repo" ]]; then
      base="$(jq -r --arg r "$root_repo" '.repos[$r].base' "$config")"
      repo_path="$(resolve_repo_path "$root_repo")"
      baseline="$(resolve_baseline "$repo_path" "$base" "$root_repo")"
      IFS='|' read -r remote base hash <<< "$baseline"
      baseline_records+=("$root_repo|$remote|$base|$hash")
      log "  worktree(root): $root_repo (base $remote/$base @ $hash) -> $task_dir 分支 $branch_name"
      git -C "$repo_path" worktree add --no-track "$task_dir" -b "$branch_name" "$hash"
    else
      mkdir -p "$task_dir"
    fi

    # 第二轮:子 repos 嵌套进 $task_dir/$repo
    for repo in "${sub_repos[@]}"; do
      base="$(jq -r --arg r "$repo" '.repos[$r].base' "$config")"
      repo_path="$(resolve_repo_path "$repo")"
      baseline="$(resolve_baseline "$repo_path" "$base" "$repo")"
      IFS='|' read -r remote base hash <<< "$baseline"
      baseline_records+=("$repo|$remote|$base|$hash")
      log "  worktree: $repo (base $remote/$base @ $hash) -> $task_dir/$repo 分支 $branch_name"
      git -C "$repo_path" worktree add --no-track "$task_dir/$repo" -b "$branch_name" "$hash"
    done
    baseline_md=""
    for record in "${baseline_records[@]}"; do
      IFS='|' read -r repo remote base hash <<< "$record"
      baseline_md+="- $repo: $remote/$base @ $hash"$'\n'
    done
    cat > "$task_dir/TASK.md" <<EOF
# 任务:$task

> 由 dispatcher 蒸馏需求后填写。worker 进 worktree 后先读本文件。freestanding,不进 git。

## 基线

${baseline_md:-<未创建 repo worktree>}

## 协作链路

- Issue: <待创建/待关联>
- MR: <待创建>
- 看板: <跟随 GitLab Issue/MR>

## 需求

<做什么、为什么>

## 验收标准

<怎样算完成>

## 代码地图

<相关文件、入口、参考实现、要避开的坑>

## 涉及仓库

$repos
EOF
    log "created: $task_dir"
    ;;

  list)
    worktree_root="$(jq -r '.worktree_root' "$config")"
    for d in "$worktree_root"/*/; do
      [[ -d "$d" ]] || continue
      basename "$d"
    done
    ;;

  remove)
    repos_root="$(jq -r '.repos_root' "$config")"
    worktree_root="$(jq -r '.worktree_root' "$config")"
    task_dir="$worktree_root/$task"
    log "remove task=$task config=$config"

    # 工具函数(remove 段重复了一份):
    resolve_repo_path() {
      local repo="$1"
      local path_override
      path_override="$(jq -r --arg r "$repo" '.repos[$r].path // ""' "$config")"
      if [[ -z "$path_override" ]]; then
        echo "$repos_root/$repo"
      elif [[ "$path_override" == "." ]]; then
        echo "$repos_root"
      elif [[ "$path_override" == /* ]]; then
        echo "$path_override"
      else
        echo "$repos_root/$path_override"
      fi
    }

    # 顺序:先嵌套 sub repo,再 root repo($task_dir 本身)。否则 root remove 后 sub worktree 已没了。
    root_repo=""
    sub_repos=()
    while IFS= read -r repo; do
      path_override="$(jq -r --arg r "$repo" '.repos[$r].path // ""' "$config")"
      if [[ "$path_override" == "." ]]; then
        root_repo="$repo"
      else
        sub_repos+=("$repo")
      fi
    done < <(jq -r '.repos | keys[]' "$config")

    # 先 remove sub repos
    for repo in "${sub_repos[@]}"; do
      wt="$task_dir/$repo"
      [[ -d "$wt" ]] || continue
      repo_path="$(resolve_repo_path "$repo")"
      log "  removed worktree: $repo"
      git -C "$repo_path" worktree remove --force "$wt"
    done

    # 再 remove root repo(其 worktree target 是 $task_dir 本身)
    if [[ -n "$root_repo" && -d "$task_dir" ]]; then
      repo_path="$(resolve_repo_path "$root_repo")"
      log "  removed worktree(root): $root_repo @ $task_dir"
      git -C "$repo_path" worktree remove --force "$task_dir"
    fi

    rm -rf "$task_dir"
    log "removed: $task_dir"
    ;;

  *)
    usage
    exit 1
    ;;
esac
