#!/usr/bin/env bash
# worktree-task — 多仓库任务工作区管理(非交互、项目无关、读 JSON 配置)
#
#   worktree-task create --config <p> --task <id> --repos <r1,r2>
#   worktree-task list   --config <p>
#   worktree-task remove --config <p> --task <id>
set -euo pipefail

die() { echo "worktree-task: $*" >&2; exit 1; }
log() { echo "[worktree-task] $*" >&2; }
usage() {
  cat >&2 <<'EOF'
worktree-task — 多仓库任务工作区管理

用法:
  worktree-task create --config <p> --task <id> [--repos <r1,r2>]
  worktree-task list   --config <p>
  worktree-task remove --config <p> --task <id>

注: --repos 不传时默认 config 里所有 repos(全切,省得判断)。
    如果配置里有 "path": "." 的 root repo,它的 worktree 占 $task_dir 顶层,
    其他子 repos 嵌套在 $task_dir/<repo>/ 下(跟主仓库结构一致)。
EOF
}

cmd="${1:-}"
shift || true

config="" task="" repos=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --config) config="$2"; shift 2 ;;
    --task)   task="$2";   shift 2 ;;
    --repos)  repos="$2";  shift 2 ;;
    *) shift ;;
  esac
done

case "$cmd" in create|list|remove)
  [[ -f "$config" ]] || die "config 文件不存在: ${config:-（未提供 --config）}"
;; esac

case "$cmd" in
  create)
    repos_root="$(jq -r '.repos_root' "$config")"
    worktree_root="$(jq -r '.worktree_root' "$config")"
    task_dir="$worktree_root/$task"
    [[ -e "$task_dir" ]] && die "任务工作区已存在: $task_dir（先 remove,或换 task id）"
    # 不传 --repos 时默认所有 config 里的 repos(全切,省得判定哪些用得到)
    if [[ -z "$repos" ]]; then
      repos="$(jq -r '.repos | keys | join(",")' "$config")"
    fi
    log "create task=$task repos=$repos config=$config"
    mkdir -p "$worktree_root"

    # 工具函数:解析 repo path
    resolve_repo_path() {
      local repo="$1"
      local path_override
      path_override="$(jq -r --arg r "$repo" '.repos[$r].path // ""' "$config")"
      if [[ -z "$path_override" ]]; then
        echo "$repos_root/$repo"
      elif [[ "$path_override" == "." ]]; then
        echo "$repos_root"
      elif [[ "$path_override" == /* ]]; then
        echo "$path_override"
      else
        echo "$repos_root/$path_override"
      fi
    }

    # 工具函数:解析基线(本地分支 → origin → die)
    resolve_start_ref() {
      local repo_path="$1" base="$2" repo="$3"
      if git -C "$repo_path" show-ref --verify --quiet "refs/heads/$base"; then
        echo "$base"
      elif git -C "$repo_path" show-ref --verify --quiet "refs/remotes/origin/$base"; then
        echo "origin/$base"
      else
        die "基线分支不存在: $base（repo $repo)"
      fi
    }

    # 分两轮处理:
    # 1) path="." 的 root repo 的 worktree target 是 $task_dir 本身(占顶层),
    #    且必须先处理(它创建 $task_dir 这个目录,其他 repo 才能嵌套进去)
    # 2) 其他子 repo 的 worktree target 是 $task_dir/$repo(嵌套位置,被 root 的 .gitignore 屏蔽)
    IFS=',' read -ra repo_list <<< "$repos"

    root_repo=""
    sub_repos=()
    for repo in "${repo_list[@]}"; do
      path_override="$(jq -r --arg r "$repo" '.repos[$r].path // ""' "$config")"
      if [[ "$path_override" == "." ]]; then
        [[ -n "$root_repo" ]] && die "只能有一个 root repo(path=\".\"): 已有 $root_repo,又来 $repo"
        root_repo="$repo"
      else
        sub_repos+=("$repo")
      fi
    done

    # 第一轮:root repo(如有)
    if [[ -n "$root_repo" ]]; then
      base="$(jq -r --arg r "$root_repo" '.repos[$r].base' "$config")"
      repo_path="$(resolve_repo_path "$root_repo")"
      start="$(resolve_start_ref "$repo_path" "$base" "$root_repo")"
      log "  worktree(root): $root_repo (base $start) -> $task_dir 分支 task/$task"
      git -C "$repo_path" worktree add --no-track "$task_dir" -b "task/$task" "$start"
    else
      mkdir -p "$task_dir"
    fi

    # 第二轮:子 repos 嵌套进 $task_dir/$repo
    for repo in "${sub_repos[@]}"; do
      base="$(jq -r --arg r "$repo" '.repos[$r].base' "$config")"
      repo_path="$(resolve_repo_path "$repo")"
      start="$(resolve_start_ref "$repo_path" "$base" "$repo")"
      log "  worktree: $repo (base $start) -> $task_dir/$repo 分支 task/$task"
      git -C "$repo_path" worktree add --no-track "$task_dir/$repo" -b "task/$task" "$start"
    done
    cat > "$task_dir/TASK.md" <<EOF
# 任务:$task

> 由 dispatcher 蒸馏需求后填写。worker 进 worktree 后先读本文件。freestanding,不进 git。

## 需求

<做什么、为什么>

## 验收标准

<怎样算完成>

## 代码地图

<相关文件、入口、参考实现、要避开的坑>

## 涉及仓库

$repos
EOF
    log "created: $task_dir"
    ;;

  list)
    worktree_root="$(jq -r '.worktree_root' "$config")"
    for d in "$worktree_root"/*/; do
      [[ -d "$d" ]] || continue
      basename "$d"
    done
    ;;

  remove)
    repos_root="$(jq -r '.repos_root' "$config")"
    worktree_root="$(jq -r '.worktree_root' "$config")"
    task_dir="$worktree_root/$task"
    log "remove task=$task config=$config"

    # 工具函数(remove 段重复了一份):
    resolve_repo_path() {
      local repo="$1"
      local path_override
      path_override="$(jq -r --arg r "$repo" '.repos[$r].path // ""' "$config")"
      if [[ -z "$path_override" ]]; then
        echo "$repos_root/$repo"
      elif [[ "$path_override" == "." ]]; then
        echo "$repos_root"
      elif [[ "$path_override" == /* ]]; then
        echo "$path_override"
      else
        echo "$repos_root/$path_override"
      fi
    }

    # 顺序:先嵌套 sub repo,再 root repo($task_dir 本身)。否则 root remove 后 sub worktree 已没了。
    root_repo=""
    sub_repos=()
    while IFS= read -r repo; do
      path_override="$(jq -r --arg r "$repo" '.repos[$r].path // ""' "$config")"
      if [[ "$path_override" == "." ]]; then
        root_repo="$repo"
      else
        sub_repos+=("$repo")
      fi
    done < <(jq -r '.repos | keys[]' "$config")

    # 先 remove sub repos
    for repo in "${sub_repos[@]}"; do
      wt="$task_dir/$repo"
      [[ -d "$wt" ]] || continue
      repo_path="$(resolve_repo_path "$repo")"
      log "  removed worktree: $repo"
      git -C "$repo_path" worktree remove --force "$wt"
    done

    # 再 remove root repo(其 worktree target 是 $task_dir 本身)
    if [[ -n "$root_repo" && -d "$task_dir" ]]; then
      repo_path="$(resolve_repo_path "$root_repo")"
      log "  removed worktree(root): $root_repo @ $task_dir"
      git -C "$repo_path" worktree remove --force "$task_dir"
    fi

    rm -rf "$task_dir"
    log "removed: $task_dir"
    ;;

  *)
    usage
    exit 1
    ;;
esac
